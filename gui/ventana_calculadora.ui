   <string notr="true">QDialog {
    background-color: #1a0f0f; /* fondo oscuro rojizo */
    color: #f5d27a; /* texto dorado suave */
    font-family: &quot;Segoe UI&quot;, Arial;
    font-size: 10pt;
}

/* Etiquetas */
QLabel {
    color: #e6c068; /* dorado */
    font-weight: bold;
}
/* Etiquetas */
QLabel#label_Resultado {
    color: #e6c068; /* dorado */
	font-size:48pt;
	font-family: &quot;Segoe UI&quot;, Romanl; 
    font-weight: bold;
}
/* Campos de texto */
QLineEdit {
    background-color: #2b1a1a;
    border: 2px solid #7a1f1f;
    border-radius: 6px;
    padding: 5px;
    color: #f5d27a;
    selection-background-color: #a83232;
}

/* Hover y focus */
QLineEdit:focus {
    border: 2px solid #d4af37; /* dorado brillante */
    background-color: #331f1f;
}

/* Botones */
QPushButton {
    background-color: #7a1f1f;
    color: #f5d27a;
    border: 2px solid #d4af37;
    border-radius: 8px;
    padding: 6px 12px;
    font-weight: bold;
}

/* Hover botón */
QPushButton:hover {
    background-color: #a83232;
    border: 2px solid #ffd700;
}

/* Botón presionado */
QPushButton:pressed {
    background-color: #5c1414;
    border: 2px solid #c9a227;
}

/* Placeholder */
QLineEdit::placeholder {
    color: #bfa76a;
}</string>
